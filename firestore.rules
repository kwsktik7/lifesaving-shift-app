rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getSession() {
      return get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return request.auth != null && getSession().role == 'admin';
    }

    // 設定: 全員読み取り可、管理者のみ書き込み
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // シーズン日: 全員読み取り可、管理者のみ書き込み
    match /seasonDays/{date} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // 学生: 全員読み取り可、管理者のみ書き込み
    match /students/{studentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // 可否: 全員読み取り可、本人or管理者が書き込み
    match /availability/{availId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.studentId == getSession().studentId;
      allow update, delete: if request.auth != null
        && (resource.data.studentId == getSession().studentId || isAdmin());
    }

    // シフト: 全員読み取り可、管理者のみ書き込み
    match /shifts/{shiftId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // セッション: 自分のUIDのみ
    match /sessions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
